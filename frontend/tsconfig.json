{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "allowJs": false,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "strict": false,
    "types": ["vite/client"]
  },
  "include": ["src", "vite.config.ts", "tailwind.config.cts", "postcss.config.cts"]
}
